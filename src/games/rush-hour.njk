---
layout: game-base.njk
title: Rush Hour - Daily Sliding Block Puzzle
description: Slide the cars out of the way and guide the red car to the exit. A new puzzle every day!
pageCss: /assets/css/rush-hour.css
---
<div id="rush-hour-wrapper">

  {# ── Top controls ─────────────────────────────────────────── #}
  <div class="flex items-center justify-center gap-2 mb-3 flex-wrap">
    <div id="stopwatch"><i class="fa-solid fa-stopwatch"></i><span id="timer"> 0:00</span></div>
    <div id="move-counter" style="color: #5741AC;">0 moves</div>
    <div class="flex gap-2">
      <button id="help-btn" class="btn btn-circle btn-sm" style="background-color: #5741AC; color: white;" title="How to Play">
        <i class="fas fa-question"></i>
      </button>
      <button id="stats-btn" class="btn btn-circle btn-sm" style="background-color: #5741AC; color: white;" title="Statistics">
        <i class="fas fa-chart-bar"></i>
      </button>
      <button id="share-btn" class="btn btn-circle btn-sm" style="background-color: #5741AC; color: white; display: none;" title="Share">
        <i class="fas fa-share-alt"></i>
      </button>
    </div>
  </div>

  {# ── Board + exit label ────────────────────────────────────── #}
  <div id="board-and-exit">
    <div id="rush-hour-board">
      {# Vehicles are injected by JS #}
      <div id="win-overlay">
        <div>🎉 You solved it!</div>
        <div style="font-size:16px; font-weight:normal;">
          <span id="win-moves"></span> moves &nbsp;·&nbsp; <span id="win-time"></span>
        </div>
        <div id="win-par-line" style="font-size:14px; font-weight:normal; opacity:0.75;">
          Optimal: <span id="win-par"></span> moves<span id="win-par-diff"></span>
        </div>
        <div class="flex gap-2 mt-2">
          <button id="win-stats-btn" class="border border-gray-400 hover:bg-gray-100 text-gray-700 font-semibold py-2 px-4 rounded text-sm">
            Stats
          </button>
          <button id="win-share-btn" class="text-white font-semibold py-2 px-4 rounded text-sm" style="background-color: #5741AC;">
            Share
          </button>
        </div>
      </div>
    </div>

    {# Exit arrow #}
    <div id="exit-label">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
      <span>EXIT</span>
    </div>
  </div>

  {# ── Bottom controls ───────────────────────────────────────── #}
  <div class="flex items-center gap-2 mt-3 mb-3">
    <button id="pauseButton" class="border border-gray-400 hover:bg-gray-100 text-gray-700 font-semibold py-2 px-4 rounded">
      <i class="fa-solid fa-pause"></i>
    </button>
    <button id="reset-btn" class="bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded">Reset</button>
  </div>

  <hr class="w-full my-4 border-gray-300">
  <p class="text-center text-gray-500" id="daily-number"></p>
  <div class="text-center">
    <a href="mailto:raj@drrajshah.com?subject=Bug Report for Rush Hour Game"
       class="border border-red-500 text-red-500 hover:bg-red-50 font-semibold py-2 px-4 rounded inline-block">
      Report a Bug
    </a>
  </div>

  {# ── Help / Welcome Modal ─────────────────────────────────── #}
  <div id="helpModal" class="hidden fixed inset-0 z-50 items-center justify-center bg-black bg-opacity-50" tabindex="-1" aria-labelledby="helpLabel" aria-hidden="true">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
      <div class="flex items-center justify-between mb-4">
        <h5 class="text-2xl font-bold" id="helpLabel">How to Play</h5>
        <button type="button" class="text-gray-500 hover:text-gray-700 text-2xl leading-none" data-dismiss="modal" aria-label="Close">
          &times;
        </button>
      </div>
      <div class="modal-body space-y-3">
        <p>
          <span class="inline-block w-5 h-5 rounded-sm mr-1 align-middle" style="background:#e53e3e;"></span>
          <strong>Goal:</strong> Slide the <strong style="color:#e53e3e;">red car</strong> to the right exit on row&nbsp;3.
        </p>
        <ol class="list-decimal ml-5 space-y-1">
          <li><strong>Click</strong> any car to select it (it glows).</li>
          <li><strong>Click the arrows</strong> on each car, or use the <strong>keyboard arrows</strong>, to slide it.</li>
          <li>Cars can only move along their own axis — horizontal cars slide left/right; vertical cars slide up/down.</li>
          <li>Move blocking cars out of the way until the red car can escape!</li>
        </ol>
        <p class="text-sm text-gray-500">Press <kbd class="border rounded px-1">Esc</kbd> to deselect a car.</p>
        <div class="text-center mt-3">
          <button id="startButton" class="bg-green-500 hover:bg-green-600 text-white font-semibold py-2 px-4 rounded" style="display: none;">
            Start Puzzle
          </button>
        </div>
      </div>
    </div>
  </div>

  {# ── Pause Modal ──────────────────────────────────────────── #}
  {% Modal
    id="pause",
    title="Game Paused",
    body="
      The game is paused.
      <div class='text-center'><button id='resumeButton' class='border border-blue-500 text-blue-500 hover:bg-blue-50 font-semibold py-2 px-4 rounded'>Resume</button></div>
    "
  %}

  {# ── Stats Modal ──────────────────────────────────────────── #}
  <div id="statsModal" class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
      <h3 class="font-bold text-2xl mb-4" style="color: #5741AC;">Statistics</h3>
      <div id="stats-content" class="space-y-4">
        <div class="grid grid-cols-3 gap-4 text-center">
          <div>
            <div id="stat-played" class="text-3xl font-bold">0</div>
            <div class="text-sm">Played</div>
          </div>
          <div>
            <div id="stat-current-streak" class="text-3xl font-bold">0</div>
            <div class="text-sm">Current Streak</div>
          </div>
          <div>
            <div id="stat-max-streak" class="text-3xl font-bold">0</div>
            <div class="text-sm">Max Streak</div>
          </div>
        </div>

        <div class="divider" style="border-color: #d3d3d3;">MOVES</div>
        <div class="grid grid-cols-2 gap-4 text-center">
          <div>
            <div id="stat-best-moves" class="text-2xl font-bold">--</div>
            <div class="text-sm">Best</div>
          </div>
          <div>
            <div id="stat-avg-moves" class="text-2xl font-bold">--</div>
            <div class="text-sm">Average</div>
          </div>
        </div>

        <div class="divider" style="border-color: #d3d3d3;">TIME</div>
        <div class="grid grid-cols-2 gap-4 text-center">
          <div>
            <div id="stat-best-time" class="text-2xl font-bold">--</div>
            <div class="text-sm">Best Time</div>
          </div>
          <div>
            <div id="stat-avg-time" class="text-2xl font-bold">--</div>
            <div class="text-sm">Avg Time</div>
          </div>
        </div>

        <div id="game-complete-message" style="display: none;">
          <div class="divider" style="border-color: #d3d3d3;">NEXT PUZZLE</div>
          <div class="text-center">
            <div id="countdown-timer" class="text-2xl font-bold" style="color: #5741AC;"></div>
          </div>
        </div>
      </div>

      <div class="mt-4 flex justify-between items-center">
        <button id="stats-share-btn" class="text-white font-semibold py-2 px-4 rounded" style="background-color: #5741AC; display: none;">
          <i class="fas fa-share-alt"></i> Share
        </button>
        <button id="close-stats-btn" class="border border-gray-400 hover:bg-gray-100 text-gray-700 font-semibold py-2 px-4 rounded ml-auto">Close</button>
      </div>
    </div>
  </div>

  {# ── Share Modal ───────────────────────────────────────────── #}
  <div id="shareModal" class="fixed inset-0 bg-black bg-opacity-50 items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
      <h3 class="font-bold text-2xl mb-4" style="color: #5741AC;">Share Your Result</h3>
      <div class="space-y-4">
        <div id="share-text" class="bg-gray-100 p-4 rounded-lg font-mono text-sm whitespace-pre"></div>
        <button id="copy-share-btn" class="w-full text-white font-semibold py-2 px-4 rounded" style="background-color: #5741AC;">
          <i class="fas fa-copy"></i> Copy to Clipboard
        </button>
        <div id="copy-success" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded flex items-center gap-2" style="display: none;">
          <i class="fas fa-check"></i>
          <span>Copied to clipboard!</span>
        </div>
      </div>
      <div class="mt-4 flex justify-end">
        <button id="close-share-btn" class="border border-gray-400 hover:bg-gray-100 text-gray-700 font-semibold py-2 px-4 rounded" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>

</div>
<script>
  // Generated puzzles, injected from src/_data/rushHourPuzzles.json by 11ty.
  // Schema: { easy: [...], moderate: [...], hard: [...], expert: [...] }
  // Each entry has a `vehicles` array compatible with rush-hour.js.
  {% if rushHourPuzzles %}
  window.RUSH_HOUR_PUZZLES = {{ rushHourPuzzles | dump | safe }};
  {% else %}
  window.RUSH_HOUR_PUZZLES = null;
  {% endif %}
</script>
<script src="{{ '/assets/js/rush-hour.js' | url }}"></script>
