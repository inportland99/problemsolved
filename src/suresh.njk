{# ============================================================
   GUESTBOOK
============================================================ #}
<section class="suresh-section suresh-guestbook" id="guestbook">
  <div class="suresh-container">
    <h2 class="section-heading">The Book of Memories</h2>
    <p class="section-intro">
      These pages hold something more precious than condolences —<br>
      the moments, lessons, and stories that show us who Suresh truly is.<br>
      <em>We're not gathering well wishes. We're gathering him.</em>
    </p>

    {# Book Viewer #}
    <div class="book-wrapper">
      <p class="book-loading" id="book-loading">Opening the book of memories…</p>

      <div class="book-scene" id="book-scene" style="display:none" aria-live="polite">
        <div class="book-display">
          <div class="book-spine"></div>
          <div class="book-page-area">
            <div id="book-page-content" class="book-page-content"></div>
          </div>
        </div>
      </div>

      <div class="book-controls" id="book-controls" style="display:none">
        <button id="prev-page" class="book-nav-btn" aria-label="Previous page">&#8249;</button>
        <span id="page-counter" class="page-counter" aria-live="polite">Page 1</span>
        <button id="next-page" class="book-nav-btn" aria-label="Next page">&#8250;</button>
      </div>
    </div>

    {# Submission Form #}
    <div class="guestbook-form-wrapper" id="add-memory">
      <h3 class="form-heading">Add Your Memory</h3>
      <p class="form-intro">
        We're not looking for well wishes — we're gathering memories.<br>
        Share a moment he was there for you, something he taught you, or a story that captures 
        exactly who Suresh Shah is. Your words will live in this book forever.
      </p>

      <form id="guestbook-form" novalidate>
        {# Honeypot — invisible to real users #}
        <div style="position:absolute;left:-9999px;height:0;overflow:hidden" aria-hidden="true">
          <label>Leave this blank <input type="text" name="website" tabindex="-1" autocomplete="off"></label>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="gb-name">Your name</label>
            <input type="text" id="gb-name" name="name" required autocomplete="name" placeholder="e.g. Priya Mehta">
          </div>
          <div class="form-group">
            <label for="gb-relationship">Your relationship to Suresh</label>
            <input type="text" id="gb-relationship" name="relationship" required placeholder="e.g. Son, Friend, Colleague">
          </div>
        </div>

        <div class="form-group">
          <label for="gb-story">Your memory, lesson, or story</label>
          <textarea id="gb-story" name="story" rows="7" required
            placeholder="Tell us about a moment that stayed with you, something he said that changed the way you see the world, or a story that shows exactly who Suresh Shah is…"></textarea>
        </div>

        <div class="form-group">
          <label for="gb-media">Add a photo or short video (optional)</label>
          <input type="file" id="gb-media" name="media" accept="image/*,video/*">
          <p class="file-hint">Images up to 5 MB · Videos up to 50 MB · JPG, PNG, GIF, MP4, MOV</p>
          <div id="media-preview" class="media-preview" style="display:none" aria-live="polite"></div>
        </div>

        <div id="form-error" class="form-error" style="display:none" role="alert"></div>
        <div id="form-success" class="form-success" style="display:none" role="status">
          Thank you. Your memory has been added to the book. ♥
        </div>

        <button type="submit" id="submit-btn" class="btn-submit">Add to the Book</button>
      </form>
    </div>
  </div>
</section>

