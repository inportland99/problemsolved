---
layout: minimal.njk
title: Personal Tools
description: Personal tools and dashboards
---

<div class="min-h-screen bg-base-200">
  <!-- Auth loading -->
  <div id="auth-loading" class="flex justify-center items-center min-h-screen">
    <span class="loading loading-spinner loading-lg"></span>
  </div>

  <!-- Main content (hidden until auth confirmed) -->
  <div id="app" class="hidden">
    <div class="container mx-auto px-4 py-10 max-w-4xl">
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold">Personal Tools</h1>
        <button id="logout-btn" class="btn btn-ghost btn-sm">Logout</button>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for tool in personal_tools %}
        <a href="{{ tool.link | url }}" class="card bg-base-100 shadow hover:shadow-lg transition-shadow duration-200 no-underline">
          <div class="card-body">
            <div class="text-4xl mb-2">{{ tool.icon }}</div>
            <h2 class="card-title text-lg">{{ tool.name }}</h2>
            <p class="text-sm text-base-content/70">{{ tool.description }}</p>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script type="module">
import { getCurrentUser, signOut } from '/assets/js/supabase-client.js';

const user = await getCurrentUser();
if (!user) {
  window.location.href = '/personal/coaching-login/';
} else {
  document.getElementById('auth-loading').classList.add('hidden');
  document.getElementById('app').classList.remove('hidden');
}

document.getElementById('logout-btn').addEventListener('click', async () => {
  await signOut();
  window.location.href = '/personal/coaching-login/';
});
</script>
