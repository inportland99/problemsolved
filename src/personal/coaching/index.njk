---
layout: minimal.njk
title: Coaching Dashboard
description: Manage your coaching clients and sessions
---

<div class="min-h-screen bg-base-200">
  <!-- Header -->
  <div class="navbar bg-base-100 shadow-lg">
    <div class="flex-1">
      <a href="/personal/coaching/" class="btn btn-ghost normal-case text-xl">🎯 Coaching</a>
    </div>
    <div class="flex-none gap-2">
      <span id="user-email" class="text-sm text-gray-600"></span>
      <button id="logout-btn" class="btn btn-sm btn-outline">Logout</button>
    </div>
  </div>

  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <!-- Alert messages -->
    <div id="alert-container" class="mb-4"></div>

    <!-- Loading state -->
    <div id="loading" class="flex justify-center items-center py-12">
      <span class="loading loading-spinner loading-lg"></span>
    </div>

    <!-- Clients list -->
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold">My Clients</h1>
      <button id="add-client-btn" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Client
      </button>
    </div>

    <!-- Empty state -->
    <div id="empty-clients" class="hidden text-center py-12">
      <div class="text-6xl mb-4">🎯</div>
      <h2 class="text-2xl font-bold mb-2">No clients yet</h2>
      <p class="text-gray-600 mb-6">Add your first coaching client to get started.</p>
      <button class="btn btn-primary add-client-trigger">Add First Client</button>
    </div>

    <!-- Client cards -->
    <div id="clients-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
  </div>
</div>

{% include "coaching/client-modal.njk" %}
{% include "coaching/delete-client-modal.njk" %}

<script type="module" src="/assets/js/coaching/clients.js"></script>
