---
layout: minimal.njk
title: Coaching Sessions
description: Session log for coaching client
---

<div class="min-h-screen bg-base-200">
  <!-- Header -->
  <div class="navbar bg-base-100 shadow-lg">
    <div class="flex-1">
      <a href="/personal/coaching/" class="btn btn-ghost normal-case text-xl">🎯 Coaching</a>
    </div>
    <div class="flex-none gap-2">
      <span id="user-email" class="text-sm text-gray-600"></span>
      <button id="logout-btn" class="btn btn-sm btn-outline">Logout</button>
    </div>
  </div>

  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <!-- Alert messages -->
    <div id="alert-container" class="mb-4"></div>

    <!-- Sessions header -->
    <div class="flex items-center gap-4 mb-6">
      <a href="/personal/coaching/" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back
      </a>
      <div class="flex-1">
        <h1 class="text-3xl font-bold" id="session-client-name"></h1>
        <p class="text-sm text-gray-600" id="session-client-info"></p>
      </div>
      <button id="add-session-btn" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Session
      </button>
    </div>

    <!-- Client dashboard -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
          <h3 class="font-semibold text-sm uppercase tracking-wide text-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z" />
            </svg>
            Personal Values
          </h3>
          <div id="client-values-card" class="mt-2 text-sm text-gray-700"></div>
        </div>
      </div>
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
          <h3 class="font-semibold text-sm uppercase tracking-wide text-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.847 5.681a1 1 0 00.95.69h5.969c.969 0 1.371 1.24.588 1.81l-4.828 3.51a1 1 0 00-.364 1.118l1.847 5.682c.3.921-.755 1.688-1.539 1.118l-4.828-3.51a1 1 0 00-1.176 0l-4.828 3.51c-.783.57-1.838-.197-1.539-1.118l1.847-5.682a1 1 0 00-.364-1.118L2.605 11.108c-.783-.57-.38-1.81.588-1.81h5.969a1 1 0 00.95-.69l1.847-5.681z" />
            </svg>
            Strengths &amp; Gifts
          </h3>
          <div id="client-strengths-card" class="mt-2 text-sm text-gray-700"></div>
        </div>
      </div>
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
          <h3 class="font-semibold text-sm uppercase tracking-wide text-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Goals &amp; Dreams
          </h3>
          <div id="client-goals-card" class="mt-2 text-sm text-gray-700"></div>
        </div>
      </div>
      <div class="card bg-base-100 shadow">
        <div class="card-body p-4">
          <h3 class="font-semibold text-sm uppercase tracking-wide text-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
            </svg>
            Remember
          </h3>
          <div id="client-notes-card" class="mt-2 text-sm text-gray-700 whitespace-pre-line"></div>
        </div>
      </div>
    </div>

    <!-- Empty sessions -->
    <div id="empty-sessions" class="hidden text-center py-12">
      <div class="text-6xl mb-4">📋</div>
      <h2 class="text-2xl font-bold mb-2">No sessions yet</h2>
      <p class="text-gray-600 mb-6">Log your first session with this client.</p>
      <button class="btn btn-primary" id="add-first-session-btn">Log First Session</button>
    </div>

    <!-- Sessions list -->
    <div id="sessions-list" class="space-y-4"></div>
  </div>
</div>

{% include "coaching/session-modal.njk" %}
{% include "coaching/view-session-modal.njk" %}
{% include "coaching/delete-session-modal.njk" %}

<style>
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>

<script type="module" src="/assets/js/coaching/sessions.js"></script>
