---
layout: minimal.njk
title: ACT Math Practice
description: Daily ACT math practice with spaced repetition
permalink: /personal/act-practice/
---

<!-- KaTeX CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">

<style>
  @media print {
    .no-print { display: none !important; }
    #print-report { display: block !important; }
    body { background: white; }

    .pr-header { margin-bottom: 1rem; border-bottom: 2px solid #5741AC; padding-bottom: 0.5rem; }
    .pr-header h1 { font-size: 1.4rem; font-weight: bold; color: #5741AC; margin: 0; }
    .pr-header p  { font-size: 0.85rem; color: #555; margin: 0.2rem 0 0; }

    .pr-problem { margin-bottom: 1.1rem; padding: 0.6rem 0.8rem; border: 1px solid #ddd;
                  border-radius: 6px; page-break-inside: avoid; }
    .pr-problem.wrong   { border-left: 4px solid #ef4444; }
    .pr-problem.correct { border-left: 4px solid #22c55e; }

    .pr-meta  { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; color: #666; margin-bottom: 0.4rem; }
    .pr-num   { font-weight: bold; color: #333; }
    .pr-topic { background: #ede9fe; color: #5741AC; padding: 1px 6px; border-radius: 10px; font-size: 0.72rem; }
    .pr-result     { margin-left: auto; font-weight: bold; }
    .pr-result.ok  { color: #16a34a; }
    .pr-result.bad { color: #dc2626; }

    .pr-hint { font-size: 0.72rem; color: #92400e; background: #fef3c7;
               border: 1px solid #fcd34d; border-radius: 4px;
               padding: 1px 5px; display: inline-block; margin-bottom: 0.3rem; }

    .pr-question { font-size: 0.9rem; margin-bottom: 0.45rem; line-height: 1.4; }
    .pr-choices  { font-size: 0.82rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.15rem 1rem; }
    .pr-choice   { display: flex; align-items: baseline; gap: 0.25rem; }
    .pr-choice-label { font-weight: bold; min-width: 1.1rem; }

    .pr-choice.selected-wrong  .pr-choice-label { color: #dc2626; }
    .pr-choice.selected-wrong  .pr-choice-text  { color: #dc2626; text-decoration: line-through; }
    .pr-choice.correct-answer  .pr-choice-label { color: #16a34a; }
    .pr-choice.correct-answer  .pr-choice-text  { color: #16a34a; font-weight: 600; }
    .pr-choice.selected-correct .pr-choice-label { color: #16a34a; }
    .pr-choice.selected-correct .pr-choice-text  { color: #16a34a; font-weight: 600; }
  }
  @media screen { #print-report { display: none; } }
</style>

<div class="min-h-screen bg-base-200 no-print">

  <!-- Login Screen -->
  <div id="screen-login" class="flex items-center justify-center min-h-screen px-4">
    <div class="card bg-base-100 shadow-xl w-full max-w-md">
      <div class="card-body">
        <div class="text-center mb-2">
          <div class="text-5xl mb-3">📐</div>
          <h1 class="text-2xl font-bold">ACT Math Practice</h1>
          <p class="text-base-content/60 text-sm mt-1">Daily practice · Spaced repetition</p>
        </div>
        <div class="form-control mt-4">
          <label class="label"><span class="label-text">Passphrase</span></label>
          <input id="passphrase-input" type="password" placeholder="Enter your passphrase"
                 class="input input-bordered w-full">
        </div>
        <div id="login-error" class="text-error text-sm hidden mt-1">Incorrect passphrase. Please try again.</div>
        <button id="login-btn" class="btn btn-primary w-full mt-4">
          <span id="login-btn-text">Continue</span>
          <span id="login-spinner" class="loading loading-spinner loading-sm hidden"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Home Screen -->
  <div id="screen-home" class="hidden flex items-center justify-center min-h-screen px-4">
    <div class="card bg-base-100 shadow-xl w-full max-w-md">
      <div class="card-body text-center">
        <div class="text-5xl mb-3">📐</div>
        <h1 class="text-2xl font-bold">ACT Math Practice</h1>
        <p class="text-base-content/60 text-sm mt-1 mb-6">Daily practice · Spaced repetition</p>
        <button id="start-btn" class="btn btn-primary w-full">Start Today's Practice</button>
        <button id="home-history-btn" class="btn btn-outline w-full mt-3">📅 View History</button>
        <button id="home-logout-btn" class="btn btn-ghost btn-sm mt-5 text-base-content/40">Logout</button>
      </div>
    </div>
  </div>

  <!-- Loading Screen -->
  <div id="screen-loading" class="hidden flex items-center justify-center min-h-screen">
    <div class="flex flex-col items-center gap-4">
      <span class="loading loading-spinner loading-lg text-primary"></span>
      <p class="text-base-content/60">Loading…</p>
    </div>
  </div>

  <!-- Session Screen -->
  <div id="screen-session" class="hidden max-w-2xl mx-auto px-4 py-8">
    <div class="mb-3">
      <span id="session-counter" class="text-sm font-medium text-base-content/60">0 / 20 correct</span>
    </div>
    <progress id="session-progress" class="progress progress-primary w-full mb-6" value="0" max="20"></progress>
    <div class="card bg-base-100 shadow mb-5">
      <div class="card-body">
        <div id="question-text" class="text-lg leading-relaxed min-h-[3rem]"></div>
      </div>
    </div>
    <div id="choices-container" class="flex flex-col gap-3"></div>

    <!-- Hint area -->
    <div id="hint-area" class="mt-4 space-y-2">
      <button id="hint1-btn" class="btn btn-ghost btn-xs text-warning gap-1">
        💡 Show problem type
      </button>
      <div id="hint1-content" class="hidden rounded-lg border border-yellow-200 bg-yellow-50 p-3">
        <p class="text-xs text-yellow-700 mb-0.5">Problem type:</p>
        <p id="hint1-topic" class="font-semibold text-yellow-900 text-sm"></p>
      </div>
      <div>
        <button id="hint2-btn" class="hidden btn btn-ghost btn-xs text-blue-500 gap-1">
          💡 Hint 2: See a similar solved problem
        </button>
      </div>
      <div id="hint2-content" class="hidden rounded-lg border border-blue-200 bg-blue-50 p-3">
        <p class="text-xs font-semibold text-blue-800 mb-1">Similar problem:</p>
        <div id="hint2-question" class="text-sm mb-2 leading-relaxed"></div>
        <p class="text-xs text-blue-800">Answer: <span id="hint2-answer" class="font-bold text-primary"></span></p>
      </div>
    </div>

    <div id="feedback-area" class="hidden mt-5 card border-2">
      <div class="card-body py-4 px-5">
        <div id="feedback-message" class="text-lg font-bold"></div>
        <div id="feedback-correct-wrap" class="hidden mt-1">
          <span class="text-sm text-base-content/60">Correct answer: </span>
          <span id="feedback-correct-label" class="font-semibold text-sm"></span>
          <span id="feedback-correct-math" class="text-sm ml-1"></span>
        </div>
        <button id="next-btn" class="btn btn-primary btn-sm mt-3 w-fit">Next →</button>
      </div>
    </div>
  </div>

  <!-- Summary Screen -->
  <div id="screen-summary" class="hidden max-w-2xl mx-auto px-4 py-10">
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body text-center">
        <div class="text-5xl mb-2">🎉</div>
        <h2 class="text-2xl font-bold mb-1">Session Complete!</h2>
        <div id="summary-encouragement" class="text-base-content/60 text-sm mb-6"></div>
        <div class="stats stats-vertical sm:stats-horizontal shadow w-full">
          <div class="stat">
            <div class="stat-title">Score</div>
            <div id="summary-score" class="stat-value text-primary">0/20</div>
          </div>
          <div class="stat">
            <div class="stat-title">Attempts</div>
            <div id="summary-correct" class="stat-value text-base-content">0</div>
          </div>
          <div class="stat">
            <div class="stat-title">Time</div>
            <div id="summary-time" class="stat-value">—</div>
          </div>
          <div class="stat">
            <div class="stat-title">Problems due tomorrow</div>
            <div id="summary-tomorrow" class="stat-value text-warning">0</div>
          </div>
        </div>
        <div class="flex gap-3 mt-6 justify-center flex-wrap">
          <button id="print-btn" class="btn btn-outline btn-sm">🖨 Print Report</button>
          <button id="done-btn" class="btn btn-primary">Done</button>
        </div>
      </div>
    </div>
  </div>

  <!-- All Done Screen (nothing due today) -->
  <div id="screen-done" class="hidden flex items-center justify-center min-h-screen px-4">
    <div class="card bg-base-100 shadow-xl w-full max-w-md text-center">
      <div class="card-body">
        <div class="text-5xl mb-3">✅</div>
        <h2 class="text-2xl font-bold">All caught up for today!</h2>
        <p class="text-base-content/60 mt-2 text-sm">Great work. Come back tomorrow for your next set of problems.</p>
        <div id="done-next-count" class="badge badge-outline mt-4 mx-auto"></div>
        <div class="flex gap-3 mt-5 justify-center">
          <button id="done-history-btn" class="btn btn-outline btn-sm">📅 View History</button>
          <button id="done-home-btn" class="btn btn-ghost btn-sm">← Home</button>
        </div>
      </div>
    </div>
  </div>

  <!-- History Screen -->
  <div id="screen-history" class="hidden max-w-2xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">📅 Practice History</h2>
      <button id="history-back-btn" class="btn btn-ghost btn-sm">← Home</button>
    </div>
    <div id="history-loading" class="text-center py-10">
      <span class="loading loading-spinner loading-md text-primary"></span>
    </div>
    <div id="history-list" class="hidden flex flex-col gap-3"></div>
    <div id="history-empty" class="hidden text-center text-base-content/60 py-10">
      No sessions recorded yet. Complete a practice session to see your history here.
    </div>
  </div>

</div>

<!-- Print Report (screen-hidden, print-visible) -->
<div id="print-report"></div>

<!-- Embed problem data at build time -->
<script>
window.ACT_PROBLEMS = {{ act_problems | dump | safe }};
</script>

