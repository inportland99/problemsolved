<!-- ═══ ADD/EDIT CLIENT MODAL ═══ -->
<dialog id="client-modal" class="modal">
  <div class="modal-box max-w-lg">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <h3 class="font-bold text-lg mb-4" id="client-modal-title">Add Client</h3>

    <input type="hidden" id="client-edit-id">

    <div class="space-y-4">
      <div class="form-control">
        <label class="label"><span class="label-text">Name *</span></label>
        <input type="text" id="client-name" class="input input-bordered" placeholder="Client name" required>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">Email</span></label>
        <input type="email" id="client-email" class="input input-bordered" placeholder="client@email.com">
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">Phone</span></label>
        <input type="tel" id="client-phone" class="input input-bordered" placeholder="555-123-4567">
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">Notes</span></label>
        <textarea id="client-notes" class="textarea textarea-bordered h-20" placeholder="General notes about this client..."></textarea>
      </div>
    </div>

    <div class="modal-action">
      <button id="save-client-btn" class="btn btn-primary">Save Client</button>
      <form method="dialog">
        <button class="btn">Cancel</button>
      </form>
    </div>
  </div>
</dialog>
