<!-- ═══ DELETE SESSION MODAL ═══ -->
<dialog id="delete-session-modal" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg mb-4">Delete Session?</h3>
    <p class="mb-4">Are you sure you want to delete this session log? This action cannot be undone.</p>
    <input type="hidden" id="delete-session-id">
    <div class="modal-action">
      <button id="confirm-delete-session" class="btn btn-error">Delete</button>
      <form method="dialog">
        <button class="btn">Cancel</button>
      </form>
    </div>
  </div>
</dialog>
