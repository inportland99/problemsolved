<!-- ═══ VIEW SESSION MODAL ═══ -->
<dialog id="view-session-modal" class="modal">
  <div class="modal-box max-w-2xl">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <h3 class="font-bold text-2xl mb-2" id="view-session-date-title"></h3>

    <div class="mb-6">
      <p class="text-sm text-gray-600 mb-2">Summary</p>
      <div class="p-4 bg-base-200 rounded-lg">
        <p id="view-session-summary" class="whitespace-pre-wrap"></p>
      </div>
    </div>

    <div id="view-notes-section" class="mb-6 hidden">
      <p class="text-sm text-gray-600 mb-2">My Notes</p>
      <div class="p-4 bg-base-200 rounded-lg">
        <p id="view-session-notes" class="whitespace-pre-wrap"></p>
      </div>
    </div>

    <div id="view-actions-section" class="mb-6 hidden">
      <p class="text-sm text-gray-600 mb-2">Action Items</p>
      <div id="view-action-items" class="space-y-2"></div>
    </div>

    <div class="modal-action">
      <button id="edit-session-from-view" class="btn btn-primary btn-sm">Edit</button>
      <button id="delete-session-from-view" class="btn btn-error btn-sm">Delete</button>
      <form method="dialog">
        <button class="btn">Close</button>
      </form>
    </div>
  </div>
</dialog>
