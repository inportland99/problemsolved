        "answerExpr": "x_sol + 1",
        "answerFormat": "integer",
        "distractorExprs": ["x_sol", "x_sol + 2", "x_sol - 1", "x_sol + 3"]
      },
      {
        "template": "What is the largest integer value of \\(x\\) that satisfies \\({a}x + {b} < {c}x + {d}\\)?",
        "params": {
          "a":     { "values": [5, 6, 7, 8] },
          "c":     { "values": [1, 2, 3, 4] },
          "x_sol": { "type": "int", "min": 2, "max": 9 }
        },
        "derived": {
          "diff_b_d": "Math.floor(Math.random() * 7) - 3",
          "b": "diff_b_d + 4",
          "d": "b + (a - c) * x_sol"
        },
        "answerExpr": "x_sol - 1",
        "answerFormat": "integer",
        "distractorExprs": ["x_sol", "x_sol + 1", "x_sol - 2", "x_sol + 2"]
      }
    ]
