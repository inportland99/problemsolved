[
  {
    "id": "percent-of-number",
    "topic": "Percentages",
    "difficulty": 1,
    "scenarios": [
      {
        "template": "What is {p}% of {n}?",
        "params": {
          "p": { "values": [10, 20, 25, 30, 50, 75, 80] },
          "n": { "values": [20, 40, 60, 80, 100, 120, 160, 200] }
        },
        "answerExpr": "n * p / 100",
        "answerFormat": "integer",
        "distractorExprs": ["n * p / 10", "n / p * 100", "n + p", "n - p"]
      },
      {
        "template": "{p}% of a number is {y}. What is the number?",
        "params": {
          "p": { "values": [10, 20, 25, 30, 50, 75, 80] },
          "n": { "values": [20, 40, 60, 80, 100, 120, 160, 200] }
        },
        "validate": "(n * p) % 100 === 0",
        "derived": { "y": "n * p / 100" },
        "answerExpr": "n",
        "answerFormat": "integer",
        "distractorExprs": ["y * p", "y * p / 100", "y * 100", "y + p"]
      }
    ]
  },
  {
    "id": "percent-increase",
    "topic": "Percentages",
    "difficulty": 2,
    "scenarios": [
      {
        "template": "A price increases from ${old} to ${new_val}. What is the percent increase?",
        "params": { "old": { "values": [50, 100, 200, 400] }, "r": { "values": [10, 20, 25, 50] } },
        "derived": { "new_val": "old * (100 + r) / 100" },
        "answerExpr": "r",
        "answerFormat": "integer",
        "distractorExprs": ["r + 10", "r / 2", "r * 2", "new_val - old"]
      },
      {
        "template": "A price was increased by {r}% to ${new_val}. What was the original price?",
        "params": { "old": { "values": [50, 100, 200, 400] }, "r": { "values": [10, 20, 25, 50] } },
        "derived": { "new_val": "old * (100 + r) / 100" },
        "answerExpr": "old",
        "answerFormat": "integer",
        "distractorExprs": [
          "new_val",
          "new_val * (100 - r) / 100",
          "new_val * (100 + r) / 100",
          "new_val * r / 100"
        ]
      },
      {
        "template": "A price decreases from ${old} to ${new_val}. What is the percent decrease?",
        "params": { "old": { "values": [50, 100, 200, 400] }, "r": { "values": [10, 20, 25, 50] } },
        "derived": { "new_val": "old * (100 - r) / 100" },
        "answerExpr": "r",
        "answerFormat": "integer",
        "distractorExprs": ["r + 10", "r / 2", "r * 2", "100 - r"]
      },
      {
        "template": "A price was decreased by {r}% to ${new_val}. What was the original price?",
        "params": { "old": { "values": [50, 100, 200, 400] }, "r": { "values": [10, 20, 25, 50] } },
        "derived": { "new_val": "old * (100 - r) / 100" },
        "answerExpr": "old",
        "answerFormat": "integer",
        "distractorExprs": [
          "new_val",
          "new_val * (100 + r) / 100",
          "new_val * (100 - r) / 100",
          "new_val * r / 100"
        ]
      }
    ]
  },
