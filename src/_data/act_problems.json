    "id": "solve-linear-one-var",
    "topic": "Linear Equations",
    "difficulty": 1,
    "template": "Solve for \\(x\\): \\({a}x {b_str} = {c}\\)",
    "params": {
      "a":     { "values": [2, 3, 4, 5, 6] },
      "x_sol": { "type": "int", "min": -6, "max": 6 }
    },
    "derived": {
      "b":     "Math.floor(Math.random() * 11) - 5",
      "c":     "a * x_sol + b",
      "b_str": "b >= 0 ? '+ ' + b : '- ' + Math.abs(b)"
    },
    "validate": "x_sol !== 0",
    "answerExpr": "x_sol",
    "answerFormat": "integer",
    "distractorExprs": [
      "x_sol + 1",
      "x_sol - 1",
      "-x_sol",
      "x_sol + a"
    ]
  },
  {
    "id": "solve-two-sides",
    "topic": "Linear Inequalities",
    "difficulty": 2,
    "scenarios": [
      {
        "template": "What is the smallest integer value of \\(x\\) that satisfies \\({a}x + {b} > {c}x + {d}\\)?",
