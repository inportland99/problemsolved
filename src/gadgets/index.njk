---
layout: game-base.njk
title: Math Gadgets
description: Interactive math tools and puzzles for exploration and learning
---
<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold mb-4" style="color: #5741AC;">Math Gadgets</h1>
    <p class="text-lg text-gray-600">Interactive tools for mathematical exploration and discovery!</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {% for gadget in gadgets %}
    <a href="{{ gadget.link | url }}" class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300 no-underline">
      <figure class="px-4 pt-4">
        <img src="{{ gadget.thumbnail | url }}" alt="{{ gadget.name }}" class="rounded-xl h-48 w-full object-cover">
      </figure>
      <div class="card-body">
        <h2 class="card-title text-2xl" style="color: #5741AC;">{{ gadget.name }}</h2>
        <p class="text-gray-600">{{ gadget.description }}</p>
        <div class="card-actions justify-end mt-4">
          <button class="btn btn-primary">Explore</button>
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</div>
